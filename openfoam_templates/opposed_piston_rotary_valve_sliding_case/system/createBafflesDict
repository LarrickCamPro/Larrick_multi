FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      createBafflesDict;
}

internalFacesOnly true;

baffles
{
    intakeValveAMI
    {
        type        faceZone;
        zoneName    intakeValveZone;

        patches
        {
            master
            {
                name            AMI_intake_master;
                type            cyclicAMI;
                matchTolerance  0.0001;
                neighbourPatch  AMI_intake_slave;
                transform       noOrdering;
                lowWeightCorrection 0.2;
            }
