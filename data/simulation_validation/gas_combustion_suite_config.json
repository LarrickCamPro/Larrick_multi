{
  "suite_id": "gas_combustion_v1",
  "description": "Five-regime gas combustion truth suite for the DOE core corridor using chemistry, spray, reacting-flow, closed-cylinder, and full-handoff validation legs.",
  "regime_order": [
    "chemistry",
    "spray",
    "reacting_flow",
    "closed_cylinder",
    "full_handoff"
  ],
  "prerequisites": {
    "chemistry": [],
    "spray": [],
    "reacting_flow": [
      "chemistry"
    ],
    "closed_cylinder": [],
    "full_handoff": [
      "spray",
      "reacting_flow",
      "closed_cylinder"
    ]
  },
  "strict_validation": {
    "enabled": false,
    "regimes": {
      "chemistry": {
        "reject_backends": [
          "fixture_fallback"
        ]
      },
      "spray": {
        "required_metric_authority": "live_case_fields",
        "reject_metric_authorities": [
          "sidecar_metrics"
        ],
        "reject_metric_sources": [
          "openfoam_metrics.json"
        ]
      },
      "reacting_flow": {
        "required_metric_authority": "live_case_fields",
        "reject_metric_authorities": [
          "sidecar_metrics"
        ],
        "reject_metric_sources": [
          "openfoam_metrics.json"
        ]
      }
    }
  },
